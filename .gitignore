# ==========================================================================
# Zireuz || Digital Lab - GitIgnore (Backend Node.js / Express)
# ==========================================================================
# Ignorar por completo el desarrollo del backend en este repositorio
backend/
# Dependencias locales (No se suben, se instalan en producción con npm install)
node_modules/
jspm_packages/
web_modules/

# Variables de entorno y llaves secretas (¡CRÍTICO PARA SEGURIDAD!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
.vcm_meta

# Logs del sistema, servidores y errores de ejecución
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Caché de herramientas de desarrollo e IDEs (VS Code, WebStorm, etc.)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.eslintcache

# Archivos basura del sistema operativo
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# Carpetas temporales o de cobertura de pruebas (Testing)
.coverage/
coverage/
.nyc_output
.runtime/

# Procesos en segundo plano / producción (Ej: PM2)
.pm2/
pids/
*.pid
*.seed
*.pid.lock